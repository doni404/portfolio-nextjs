# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/portfolio_db"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# Uploaded project/blog media. Mount this directory as persistent storage in production.
# Leave unset to use <project>/apps/api/storage/uploads (default via process.cwd())
# UPLOAD_DIR=/absolute/path/to/storage/uploads

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=

# ─── Admin Seed ───────────────────────────────────────────────────────────────
# Used only during db:seed — never hardcode passwords
SEED_ADMIN_PASSWORD=changeme123

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
